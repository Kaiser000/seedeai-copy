# Seede AI 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 智谱 AI LLM API Key（必填）
LLM_API_KEY=your_llm_api_key_here

# LLM API 地址（可选，默认智谱 API）
# LLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# LLM 模型名称（可选，默认 glm-4.7）
# LLM_MODEL=glm-4.7

# 图片生成 API Key（火山引擎 Seedream）
IMAGE_GENERATE_API_KEY=your_image_generate_api_key_here

# 图片生成是否启用（可选，默认 true）
# IMAGE_GENERATE_ENABLED=true

# 图片生成 API 地址（可选）
# IMAGE_GENERATE_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations

# 图片生成模型名称（可选）
# IMAGE_GENERATE_MODEL=doubao-seedream-4-0-250828

# 联网搜索（讯飞 CBM 搜索 API，可选）
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_APP_ID=your_app_id_here
# WEB_SEARCH_API_KEY=your_api_key_here
# WEB_SEARCH_API_SECRET=your_api_secret_here

# OpenRouter API Key（可选，配置后前端可选择 OpenRouter 上的多种模型）
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter API 地址（可选，默认 https://openrouter.ai/api/v1/chat/completions）
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# CORS 允许的源（可选，默认 http://localhost:5173）
# CORS_ALLOWED_ORIGINS=http://localhost:5173
