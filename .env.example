# Seede AI 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 智谱 AI LLM API Key（必填）
LLM_API_KEY=your_llm_api_key_here

# LLM API 地址（可选，默认智谱 API）
# LLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# LLM 模型名称（可选，默认 glm-4.7）
# LLM_MODEL=glm-4.7

# 图片生成 API Key（火山引擎 Seedream）
IMAGE_GENERATE_API_KEY=your_image_generate_api_key_here

# 图片生成是否启用（可选，默认 true）
# IMAGE_GENERATE_ENABLED=true

# 图片生成 API 地址（可选）
# IMAGE_GENERATE_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations

# 图片生成模型名称（可选）
# IMAGE_GENERATE_MODEL=doubao-seedream-4-0-250828

# CORS 允许的源（可选，默认 http://localhost:5173）
# CORS_ALLOWED_ORIGINS=http://localhost:5173
